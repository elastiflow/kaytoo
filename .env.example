# Example environment for local development.
# Copy to `.env` and replace placeholders.
# Full variable list is available in the README.md file.

# LLM:
LLM_BASE_URL=http://example.ai.org:3000
LLM_API_KEY=""
LLM_MODEL=gpt-5.4-codex

# Logging:
LOG_LEVEL=info

# OpenSearch:
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=""
OPENSEARCH_TLS_INSECURE=true
OPENSEARCH_INDEX_PATTERN=elastiflow-flow-codex-*
